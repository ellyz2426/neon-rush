  <text name="btn-resume" fontSize="14" fontWeight="bold" color="#00ffff" backgroundColor="#003344" borderColor="#00ffff" borderWidth="1" borderRadius="4" padding="6" width="180" textAlign="center" cursor="pointer">RESUME</text>
  <text name="btn-quit" fontSize="14" fontWeight="bold" color="#ff4444" backgroundColor="#330000" borderColor="#ff4444" borderWidth="1" borderRadius="4" padding="6" width="180" textAlign="center" cursor="pointer">QUIT TO MENU</text>
</container>
