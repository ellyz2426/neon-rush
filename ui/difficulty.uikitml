<container flexDirection="column" alignItems="center" justifyContent="center" gap="6" width="280" height="300">
  <text fontSize="22" fontWeight="bold" color="#00ffff">DIFFICULTY</text>
  <text name="diff-label" fontSize="10" color="#aaaaaa">NORMAL</text>
  <text name="btn-easy" fontSize="14" fontWeight="bold" color="#44ff44" backgroundColor="#003300" borderColor="#44ff44" borderWidth="1" borderRadius="4" padding="6" width="200" textAlign="center" cursor="pointer">EASY</text>
  <text name="btn-normal" fontSize="14" fontWeight="bold" color="#00ffff" backgroundColor="#003333" borderColor="#00ffff" borderWidth="1" borderRadius="4" padding="6" width="200" textAlign="center" cursor="pointer">NORMAL</text>
  <text name="btn-hard" fontSize="14" fontWeight="bold" color="#ff8800" backgroundColor="#332200" borderColor="#ff8800" borderWidth="1" borderRadius="4" padding="6" width="200" textAlign="center" cursor="pointer">HARD</text>
  <text name="btn-insane" fontSize="14" fontWeight="bold" color="#ff4444" backgroundColor="#330000" borderColor="#ff4444" borderWidth="1" borderRadius="4" padding="6" width="200" textAlign="center" cursor="pointer">INSANE</text>
  <text name="btn-diff-back" fontSize="12" color="#aaaaaa" backgroundColor="#222222" borderRadius="4" padding="5" width="120" textAlign="center" cursor="pointer" marginTop="4">BACK</text>
</container>
