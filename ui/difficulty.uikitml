<container flexDirection="column" alignItems="center" justifyContent="center" gap="6" width="280" height="200">
  <text fontSize="18" fontWeight="bold" color="#00ffff">DIFFICULTY</text>
  <container flexDirection="column" gap="4" alignItems="center" width="240">
    <text name="btn-easy" fontSize="14" fontWeight="bold" color="#44ff44" backgroundColor="#003300" borderColor="#44ff44" borderWidth="1" borderRadius="4" padding="6" width="200" textAlign="center" cursor="pointer">EASY</text>
    <text name="btn-medium" fontSize="14" fontWeight="bold" color="#ffaa00" backgroundColor="#332200" borderColor="#ffaa00" borderWidth="1" borderRadius="4" padding="6" width="200" textAlign="center" cursor="pointer">MEDIUM</text>
    <text name="btn-hard" fontSize="14" fontWeight="bold" color="#ff4444" backgroundColor="#330000" borderColor="#ff4444" borderWidth="1" borderRadius="4" padding="6" width="200" textAlign="center" cursor="pointer">HARD</text>
  </container>
  <text name="btn-back" fontSize="12" color="#888888" backgroundColor="#222222" borderColor="#666666" borderWidth="1" borderRadius="4" padding="4" width="100" textAlign="center" cursor="pointer">BACK</text>
</container>
