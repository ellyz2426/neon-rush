<container flexDirection="column" alignItems="center" justifyContent="center" gap="3" width="320" height="400">
  <text fontSize="18" fontWeight="bold" color="#00ffff">SELECT LEVEL</text>
  <container flexDirection="row" flexWrap="wrap" gap="3" justifyContent="center" width="300">
